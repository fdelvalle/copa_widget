{
  "info": {
    "_postman_id": "b2e7c9a4-1f3d-4c8a-9e21-copa2026fd000",
    "name": "Copa 2026 — football-data.org v4",
    "description": "Coleção completa da API football-data.org (v4) focada na Copa do Mundo (competition = WC).\n\n## Como usar\n1. A autenticação já está configurada no nível da coleção: header `X-Auth-Token` = `{{token}}`.\n2. A variável `token` já vem preenchida com sua key. Para trocar: aba **Variables** da coleção.\n3. Variáveis úteis já preenchidas: `competition` (WC), `competitionId` (2000), `teamId` (764 = Brasil), `matchId` (exemplo).\n\n## Observações\n- Plano gratuito: limite de **10 chamadas/minuto**.\n- O código `WC` funciona como id da competição nos caminhos `/competitions/WC/...`.\n- Filtro `status`: SCHEDULED, TIMED, IN_PLAY, PAUSED, LIVE, FINISHED, SUSPENDED, POSTPONED, CANCELLED, AWARDED.\n- Fases (`stage`): GROUP_STAGE, LAST_32, LAST_16, QUARTER_FINALS, SEMI_FINALS, THIRD_PLACE, FINAL.\n- Grupos (`group`): GROUP_A … GROUP_L (formato 2026 com 48 seleções).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "apikey",
    "apikey": [
      { "key": "key", "value": "X-Auth-Token", "type": "string" },
      { "key": "value", "value": "{{token}}", "type": "string" },
      { "key": "in", "value": "header", "type": "string" }
    ]
  },
  "variable": [
    { "key": "baseUrl", "value": "https://api.football-data.org/v4", "type": "string" },
    { "key": "token", "value": "cf348281b5e040a9a6cfa2b141c37340", "type": "string" },
    { "key": "competition", "value": "WC", "type": "string", "description": "Código da Copa do Mundo. Aceito como id no caminho." },
    { "key": "competitionId", "value": "2000", "type": "string", "description": "Id numérico da Copa, usado no filtro global /matches?competitions=" },
    { "key": "teamId", "value": "764", "type": "string", "description": "764 = Brazil" },
    { "key": "matchId", "value": "537327", "type": "string", "description": "Jogo de exemplo (Mexico x South Africa, abertura)" },
    { "key": "areaId", "value": "2013", "type": "string", "description": "Exemplo de área (país/continente). Veja a lista em /areas" },
    { "key": "personId", "value": "", "type": "string", "description": "Preencha com um id de jogador (ex.: vem em /teams/{{teamId}} -> squad)" },
    { "key": "today", "value": "", "type": "string", "description": "Preenchido automaticamente pelo pré-script da request 'Jogos de HOJE'" }
  ],
  "item": [
    {
      "name": "00 - Competições",
      "item": [
        {
          "name": "Listar todas as competições",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/competitions",
              "host": ["{{baseUrl}}"],
              "path": ["competitions"]
            },
            "description": "Lista todas as competições disponíveis na sua conta. Útil para descobrir o id de outras ligas."
          },
          "response": []
        },
        {
          "name": "Listar competições por área",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/competitions?areas={{areaId}}",
              "host": ["{{baseUrl}}"],
              "path": ["competitions"],
              "query": [ { "key": "areas", "value": "{{areaId}}" } ]
            },
            "description": "Filtra competições por uma ou mais áreas (ids separados por vírgula)."
          },
          "response": []
        },
        {
          "name": "Detalhe da Copa (WC)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/competitions/{{competition}}",
              "host": ["{{baseUrl}}"],
              "path": ["competitions", "{{competition}}"]
            },
            "description": "Dados gerais da Copa do Mundo: temporada atual, datas, etc."
          },
          "response": []
        },
        {
          "name": "Classificação — atual",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/competitions/{{competition}}/standings",
              "host": ["{{baseUrl}}"],
              "path": ["competitions", "{{competition}}", "standings"]
            },
            "description": "Tabela de classificação por grupo (type TOTAL/HOME/AWAY)."
          },
          "response": []
        },
        {
          "name": "Classificação — por rodada (matchday)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/competitions/{{competition}}/standings?matchday=1",
              "host": ["{{baseUrl}}"],
              "path": ["competitions", "{{competition}}", "standings"],
              "query": [ { "key": "matchday", "value": "1" } ]
            },
            "description": "Classificação congelada em uma rodada específica."
          },
          "response": []
        },
        {
          "name": "Jogos — todos",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/competitions/{{competition}}/matches",
              "host": ["{{baseUrl}}"],
              "path": ["competitions", "{{competition}}", "matches"]
            },
            "description": "Todos os jogos da Copa (104 partidas no formato 2026)."
          },
          "response": []
        },
        {
          "name": "Jogos — de HOJE (data automática)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Calcula a data de hoje (YYYY-MM-DD) e grava em {{today}}",
                  "var d = new Date();",
                  "var iso = d.toISOString().slice(0, 10);",
                  "pm.collectionVariables.set('today', iso);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/competitions/{{competition}}/matches?dateFrom={{today}}&dateTo={{today}}",
              "host": ["{{baseUrl}}"],
              "path": ["competitions", "{{competition}}", "matches"],
              "query": [
                { "key": "dateFrom", "value": "{{today}}" },
                { "key": "dateTo", "value": "{{today}}" }
              ]
            },
            "description": "Jogos do dia atual. O pré-script preenche {{today}} sozinho ao enviar."
          },
          "response": []
        },
        {
          "name": "Jogos — AO VIVO",
